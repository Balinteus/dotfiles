{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git ls-files*": "allow",
      "git stash list*": "allow",
      "git describe*": "allow",
      "npm *": "allow",
      "pnpm *": "allow",
      "bun *": "allow",
      "yarn *": "allow",
      "cargo *": "allow",
      "go *": "allow",
      "pip *": "allow",
      "pip3 *": "allow",
      "uv *": "allow",
      "poetry *": "allow",
      "make *": "allow",
      "just *": "allow",
      "ninja *": "allow",
      "cmake *": "allow",
      "meson *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "file *": "allow",
      "du *": "allow",
      "df *": "allow",
      "stat *": "allow",
      "realpath *": "allow",
      "readlink *": "allow",
      "which *": "allow",
      "type *": "allow",
      "command *": "allow",
      "pwd": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "date *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "ag *": "allow",
      "find *": "allow",
      "fd *": "allow",
      "env": "allow",
      "printenv *": "allow",
      "uname *": "allow",
      "whoami": "allow",
      "hostname *": "allow",
      "id": "allow",
      "nproc": "allow",
      "direnv *": "allow"
    }
  }
}
